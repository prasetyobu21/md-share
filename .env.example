# Next.js Public Supabase URL (e.g., https://your-project-id.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url

# Next.js Public Supabase Anon/Publishable Key (used on the client)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_publishable_key

# Supabase Service Role Key (NEVER expose to the client! Used on the server for full DB/Storage privileges)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# stark password to guard the root route authentication wall
ADMIN_PASSWORD=your_secure_admin_password

